# dbbackupctl secret configuration
# This file contains passwords and sensitive data.
#
# IMPORTANT: This file should have restricted permissions:
#   chown root:dbbackup /etc/dbbackupctl/secret.env
#   chmod 600 /etc/dbbackupctl/secret.env
#
# The check command will warn if permissions are not set correctly.

# =============================================================================
# MySQL Passwords
# =============================================================================

# MySQL backup user password for prod job
MYSQL_PROD_PASSWORD='your_mysql_backup_password'

# MySQL restore user password for prod job
MYSQL_PROD_RESTORE_PASSWORD='your_mysql_restore_password'

# MySQL backup user password for staging job (if configured)
# MYSQL_STAGING_PASSWORD='your_mysql_staging_password'

# =============================================================================
# PostgreSQL Passwords
# =============================================================================

# PostgreSQL backup user password for prod job
POSTGRES_PROD_PASSWORD='your_postgres_backup_password'

# PostgreSQL restore user password for prod job
POSTGRES_PROD_RESTORE_PASSWORD='your_postgres_restore_password'

# PostgreSQL backup user password for staging job (if configured)
# POSTGRES_STAGING_PASSWORD='your_postgres_staging_password'

# =============================================================================
# Encryption Keys (Future Use)
# =============================================================================

# Encryption key for backup encryption (not implemented in v1)
# DBB_ENCRYPTION_KEY='your_encryption_key'