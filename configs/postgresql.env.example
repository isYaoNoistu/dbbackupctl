# dbbackupctl PostgreSQL configuration
# This file contains PostgreSQL backup job configurations.

# =============================================================================
# Global PostgreSQL Settings
# =============================================================================

# Enable PostgreSQL backups (default: true)
POSTGRES_ENABLED=true

# Comma-separated list of job names
POSTGRES_JOBS=prod

# =============================================================================
# Job: prod
# =============================================================================

# Enable this job (default: true)
POSTGRES_PROD_ENABLED=true

# Database connection
POSTGRES_PROD_HOST=127.0.0.1
POSTGRES_PROD_PORT=5432
POSTGRES_PROD_USER=backup_user

# Password environment variable name
# The actual password should be set in secret.env or as environment variable
POSTGRES_PROD_PASSWORD_ENV=POSTGRES_PROD_PASSWORD

# SSL mode: disable, require, verify-ca, verify-full (default: disable)
POSTGRES_PROD_SSLMODE=disable

# Databases to backup (comma-separated)
# Use '*' to backup all user databases
POSTGRES_PROD_DATABASES=appdb,reportdb

# Include template databases (default: false)
POSTGRES_PROD_INCLUDE_TEMPLATE_DATABASES=false

# Include postgres database (default: false)
POSTGRES_PROD_INCLUDE_POSTGRES_DATABASE=false

# =============================================================================
# Job: prod - Backup Settings
# =============================================================================

# Backup mode: logical (default: logical)
POSTGRES_PROD_BACKUP_MODE=logical

# Dump format: custom, plain, directory, tar (default: custom)
# custom: pg_restore format, supports parallel restore
# plain: SQL format, restored with psql
POSTGRES_PROD_DUMP_FORMAT=custom

# Include global objects (roles, tablespaces) (default: true)
POSTGRES_PROD_INCLUDE_GLOBALS=true

# Exclude object ownership (default: true)
POSTGRES_PROD_NO_OWNER=true

# Exclude privilege assignments (default: true)
POSTGRES_PROD_NO_PRIVILEGES=true

# Number of parallel jobs for pg_dump (default: 1)
POSTGRES_PROD_JOBS=1

# Backup directory for this job
POSTGRES_PROD_BACKUP_DIR=/data/backup/postgresql/prod

# =============================================================================
# Job: prod - Restore Settings
# =============================================================================

# Restore connection (can be different from backup connection)
POSTGRES_PROD_RESTORE_HOST=127.0.0.1
POSTGRES_PROD_RESTORE_PORT=5432
POSTGRES_PROD_RESTORE_USER=postgres

# Restore password environment variable name
POSTGRES_PROD_RESTORE_PASSWORD_ENV=POSTGRES_PROD_RESTORE_PASSWORD

# Restore SSL mode
POSTGRES_PROD_RESTORE_SSLMODE=disable

# =============================================================================
# Job: prod - Retention Policy
# =============================================================================

# Override global retention settings for this job (optional)
POSTGRES_PROD_RETENTION_KEEP_LAST=7
POSTGRES_PROD_RETENTION_KEEP_DAYS=7
POSTGRES_PROD_RETENTION_MAX_TOTAL_SIZE=300G

# =============================================================================
# Job: staging (example)
# =============================================================================

# POSTGRES_STAGING_ENABLED=true
# POSTGRES_STAGING_HOST=127.0.0.1
# POSTGRES_STAGING_PORT=5432
# POSTGRES_STAGING_USER=backup_user
# POSTGRES_STAGING_PASSWORD_ENV=POSTGRES_STAGING_PASSWORD
# POSTGRES_STAGING_DATABASES=staging_db
# POSTGRES_STAGING_BACKUP_DIR=/data/backup/postgresql/staging