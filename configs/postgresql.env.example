# dbbackupctl PostgreSQL 配置示例
# 一个 job 就是一套环境，例如 dev、uat、prod。

# =============================================================================
# PostgreSQL 全局开关
# =============================================================================

POSTGRES_ENABLED=true

# 要管理的 PostgreSQL 环境列表。命令中通过 --job 选择其中一套。
# 示例：dbbackupctl postgresql backup --job dev
# 示例：dbbackupctl check --postgresql --job prod
POSTGRES_JOBS=dev,prod

# =============================================================================
# 环境：dev
# =============================================================================

POSTGRES_DEV_ENABLED=true
POSTGRES_DEV_HOST=127.0.0.1
POSTGRES_DEV_PORT=5432
POSTGRES_DEV_USER=backup_user
POSTGRES_DEV_PASSWORD_ENV=POSTGRES_DEV_PASSWORD
# POSTGRES_DEV_PASSWORD_FILE=/etc/dbbackupctl/postgres-dev.pass
POSTGRES_DEV_SSLMODE=disable

# 要备份的数据库，多个用英文逗号分隔；使用 * 表示备份所有用户库。
POSTGRES_DEV_DATABASES=dev_app,dev_report
POSTGRES_DEV_INCLUDE_TEMPLATE_DATABASES=false
POSTGRES_DEV_INCLUDE_POSTGRES_DATABASE=false

# 备份设置
POSTGRES_DEV_BACKUP_MODE=logical
# v1 流式模式支持 custom、plain、tar；不支持 directory。
POSTGRES_DEV_DUMP_FORMAT=custom
POSTGRES_DEV_INCLUDE_GLOBALS=true
POSTGRES_DEV_NO_OWNER=true
POSTGRES_DEV_NO_PRIVILEGES=true
POSTGRES_DEV_JOBS=1
POSTGRES_DEV_BACKUP_DIR=/data/backup/postgresql/dev

# 恢复连接，可与备份连接不同。
POSTGRES_DEV_RESTORE_HOST=127.0.0.1
POSTGRES_DEV_RESTORE_PORT=5432
POSTGRES_DEV_RESTORE_USER=postgres
POSTGRES_DEV_RESTORE_PASSWORD_ENV=POSTGRES_DEV_RESTORE_PASSWORD
# POSTGRES_DEV_RESTORE_PASSWORD_FILE=/etc/dbbackupctl/postgres-dev-restore.pass
POSTGRES_DEV_RESTORE_SSLMODE=disable

POSTGRES_DEV_RETENTION_KEEP_LAST=7
POSTGRES_DEV_RETENTION_KEEP_DAYS=7
POSTGRES_DEV_RETENTION_MAX_TOTAL_SIZE=100G

# =============================================================================
# 环境：prod
# =============================================================================

POSTGRES_PROD_ENABLED=true
POSTGRES_PROD_HOST=127.0.0.1
POSTGRES_PROD_PORT=5432
POSTGRES_PROD_USER=backup_user
POSTGRES_PROD_PASSWORD_ENV=POSTGRES_PROD_PASSWORD
# POSTGRES_PROD_PASSWORD_FILE=/etc/dbbackupctl/postgres-prod.pass
POSTGRES_PROD_SSLMODE=disable

POSTGRES_PROD_DATABASES=prod_app,prod_report
POSTGRES_PROD_INCLUDE_TEMPLATE_DATABASES=false
POSTGRES_PROD_INCLUDE_POSTGRES_DATABASE=false

POSTGRES_PROD_BACKUP_MODE=logical
POSTGRES_PROD_DUMP_FORMAT=custom
POSTGRES_PROD_INCLUDE_GLOBALS=true
POSTGRES_PROD_NO_OWNER=true
POSTGRES_PROD_NO_PRIVILEGES=true
POSTGRES_PROD_JOBS=1
POSTGRES_PROD_BACKUP_DIR=/data/backup/postgresql/prod

POSTGRES_PROD_RESTORE_HOST=127.0.0.1
POSTGRES_PROD_RESTORE_PORT=5432
POSTGRES_PROD_RESTORE_USER=postgres
POSTGRES_PROD_RESTORE_PASSWORD_ENV=POSTGRES_PROD_RESTORE_PASSWORD
# POSTGRES_PROD_RESTORE_PASSWORD_FILE=/etc/dbbackupctl/postgres-prod-restore.pass
POSTGRES_PROD_RESTORE_SSLMODE=disable

POSTGRES_PROD_RETENTION_KEEP_LAST=14
POSTGRES_PROD_RETENTION_KEEP_DAYS=14
POSTGRES_PROD_RETENTION_MAX_TOTAL_SIZE=300G
