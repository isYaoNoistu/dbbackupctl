# dbbackupctl core configuration
# This file contains core settings for the backup tool.

# =============================================================================
# Directory Configuration
# =============================================================================

# Configuration directory path
DBB_CONFIG_DIR=/etc/dbbackupctl

# Data directory for index files and metadata
DBB_DATA_DIR=/data/dbbackupctl

# Root directory for backup files
DBB_BACKUP_ROOT=/data/backup

# Temporary directory for backup operations
DBB_TMP_DIR=/data/dbbackupctl/tmp

# Log directory
DBB_LOG_DIR=/var/log/dbbackupctl

# Lock directory
DBB_LOCK_DIR=/var/lock/dbbackupctl

# =============================================================================
# General Configuration
# =============================================================================

# Timezone for timestamps (default: Asia/Shanghai)
DBB_TIMEZONE=Asia/Shanghai

# Log format: json or text (default: json)
DBB_LOG_FORMAT=json

# Log level: debug, info, warn, error (default: info)
DBB_LOG_LEVEL=info

# Default backup timeout (default: 6h)
DBB_DEFAULT_TIMEOUT=6h

# =============================================================================
# Compression Configuration
# =============================================================================

# Enable compression (default: true)
DBB_COMPRESS_ENABLED=true

# Compression type: zstd or gzip (default: zstd)
DBB_COMPRESS_TYPE=zstd

# Compression level:
#   zstd: 1-22 (default: 3)
#   gzip: 1-9 (default: 6)
DBB_COMPRESS_LEVEL=3

# Compression threads: 0 = auto (default: 0)
DBB_COMPRESS_THREADS=0

# Enable streaming compression (default: true)
# When true, backup output is piped directly to compressor
# When false, backup is saved first, then compressed
DBB_STREAM_COMPRESS=true

# =============================================================================
# Checksum Configuration
# =============================================================================

# Enable checksum verification (default: true)
DBB_CHECKSUM_ENABLED=true

# Checksum type: sha256 (default: sha256)
DBB_CHECKSUM_TYPE=sha256

# =============================================================================
# Retention Policy Configuration
# =============================================================================

# Number of recent backups to keep per job (default: 7)
DBB_RETENTION_KEEP_LAST=7

# Number of days to keep backups (default: 7)
DBB_RETENTION_KEEP_DAYS=7

# Number of failed backups to keep (default: 3)
DBB_RETENTION_KEEP_FAILED_LAST=3

# Maximum total size of backups per job (default: 300G)
# Supports: K, M, G, T
DBB_RETENTION_MAX_TOTAL_SIZE=300G

# Prune before backup (default: false)
DBB_RETENTION_PRUNE_BEFORE_BACKUP=false

# Prune after backup (default: true)
DBB_RETENTION_PRUNE_AFTER_BACKUP=true

# =============================================================================
# Disk Protection Configuration
# =============================================================================

# Enable disk space protection (default: true)
DBB_DISK_GUARD_ENABLED=true

# Minimum free disk space required (default: 20G)
DBB_DISK_MIN_FREE_SIZE=20G

# Minimum free disk space percentage (default: 15)
DBB_DISK_MIN_FREE_PERCENT=15

# Buffer percentage for size estimation (default: 20)
DBB_DISK_ESTIMATE_BUFFER_PERCENT=20

# =============================================================================
# Index Configuration
# =============================================================================

# Backup records index file path
DBB_INDEX_FILE=/data/dbbackupctl/index/backup_records.jsonl

# Command run log file path
DBB_COMMAND_LOG_FILE=/data/dbbackupctl/index/command_runs.jsonl

# Restore records log file path
DBB_RESTORE_LOG_FILE=/data/dbbackupctl/index/restore_records.jsonl