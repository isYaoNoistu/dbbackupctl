# dbbackupctl 核心配置示例

DBB_CONFIG_DIR=/etc/dbbackupctl
DBB_DATA_DIR=/data/dbbackupctl
DBB_BACKUP_ROOT=/data/backup
DBB_TMP_DIR=/data/dbbackupctl/tmp
DBB_LOG_DIR=/var/log/dbbackupctl
DBB_LOCK_DIR=/var/lock/dbbackupctl

DBB_TIMEZONE=Asia/Shanghai
DBB_LOG_FORMAT=json
DBB_LOG_LEVEL=info
DBB_DEFAULT_TIMEOUT=6h

DBB_COMPRESS_ENABLED=true
DBB_COMPRESS_TYPE=zstd
DBB_COMPRESS_LEVEL=3
DBB_COMPRESS_THREADS=0
DBB_STREAM_COMPRESS=true

DBB_CHECKSUM_ENABLED=true
DBB_CHECKSUM_TYPE=sha256

DBB_RETENTION_KEEP_LAST=7
DBB_RETENTION_KEEP_DAYS=7
DBB_RETENTION_KEEP_FAILED_LAST=3
DBB_RETENTION_MAX_TOTAL_SIZE=300G
DBB_RETENTION_PRUNE_BEFORE_BACKUP=false
DBB_RETENTION_PRUNE_AFTER_BACKUP=true

DBB_DISK_GUARD_ENABLED=true
DBB_DISK_MIN_FREE_SIZE=20G
DBB_DISK_MIN_FREE_PERCENT=15
DBB_DISK_ESTIMATE_BUFFER_PERCENT=20

DBB_INDEX_FILE=/data/dbbackupctl/index/backup_records.jsonl
DBB_COMMAND_LOG_FILE=/data/dbbackupctl/index/command_runs.jsonl
DBB_RESTORE_LOG_FILE=/data/dbbackupctl/index/restore_records.jsonl
