# dbbackupctl MySQL configuration
# This file contains MySQL backup job configurations.

# =============================================================================
# Global MySQL Settings
# =============================================================================

# Enable MySQL backups (default: true)
MYSQL_ENABLED=true

# Comma-separated list of job names
MYSQL_JOBS=prod

# =============================================================================
# Job: prod
# =============================================================================

# Enable this job (default: true)
MYSQL_PROD_ENABLED=true

# Database connection
MYSQL_PROD_HOST=127.0.0.1
MYSQL_PROD_PORT=3306
MYSQL_PROD_USER=backup_user

# Password environment variable name
# The actual password should be set in secret.env or as environment variable
MYSQL_PROD_PASSWORD_ENV=MYSQL_PROD_PASSWORD

# Databases to backup (comma-separated)
# Use '*' to backup all user databases
MYSQL_PROD_DATABASES=aloof,easewise

# Include system databases: mysql, sys, performance_schema, information_schema (default: false)
MYSQL_PROD_INCLUDE_SYSTEM_DATABASES=false

# =============================================================================
# Job: prod - Backup Settings
# =============================================================================

# Backup mode: logical (default: logical)
MYSQL_PROD_BACKUP_MODE=logical

# Output mode: per_database or single_file (default: per_database)
MYSQL_PROD_OUTPUT_MODE=per_database

# Backup directory for this job
MYSQL_PROD_BACKUP_DIR=/data/backup/mysql/prod

# mysqldump options
MYSQL_PROD_SINGLE_TRANSACTION=true
MYSQL_PROD_QUICK=true
MYSQL_PROD_ROUTINES=true
MYSQL_PROD_EVENTS=true
MYSQL_PROD_TRIGGERS=true
MYSQL_PROD_HEX_BLOB=true
MYSQL_PROD_SET_GTID_PURGED=OFF
MYSQL_PROD_COLUMN_STATISTICS=false
MYSQL_PROD_LOCK_TABLES=false
MYSQL_PROD_DUMP_CREATE_DATABASE=false

# =============================================================================
# Job: prod - Restore Settings
# =============================================================================

# Restore connection (can be different from backup connection)
MYSQL_PROD_RESTORE_HOST=127.0.0.1
MYSQL_PROD_RESTORE_PORT=3306
MYSQL_PROD_RESTORE_USER=root

# Restore password environment variable name
MYSQL_PROD_RESTORE_PASSWORD_ENV=MYSQL_PROD_RESTORE_PASSWORD

# =============================================================================
# Job: prod - Retention Policy
# =============================================================================

# Override global retention settings for this job (optional)
MYSQL_PROD_RETENTION_KEEP_LAST=7
MYSQL_PROD_RETENTION_KEEP_DAYS=7
MYSQL_PROD_RETENTION_MAX_TOTAL_SIZE=300G

# =============================================================================
# Job: staging (example)
# =============================================================================

# MYSQL_STAGING_ENABLED=true
# MYSQL_STAGING_HOST=127.0.0.1
# MYSQL_STAGING_PORT=3306
# MYSQL_STAGING_USER=backup_user
# MYSQL_STAGING_PASSWORD_ENV=MYSQL_STAGING_PASSWORD
# MYSQL_STAGING_DATABASES=staging_db
# MYSQL_STAGING_BACKUP_DIR=/data/backup/mysql/staging