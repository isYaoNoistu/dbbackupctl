# dbbackupctl MySQL 配置示例
# 一个 job 就是一套环境，例如 dev、uat、prod。

MYSQL_ENABLED=true

# 要管理的 MySQL 环境列表。命令中通过 --job 选择其中一套。
MYSQL_JOBS=dev,prod

# =============================================================================
# 环境：dev
# =============================================================================

MYSQL_DEV_ENABLED=true
MYSQL_DEV_HOST=127.0.0.1
MYSQL_DEV_PORT=3306
MYSQL_DEV_USER=backup_user
MYSQL_DEV_PASSWORD_ENV=MYSQL_DEV_PASSWORD
# MYSQL_DEV_PASSWORD_FILE=/etc/dbbackupctl/mysql-dev.pass
MYSQL_DEV_DATABASES=dev_app,dev_report
MYSQL_DEV_INCLUDE_SYSTEM_DATABASES=false
MYSQL_DEV_BACKUP_MODE=logical
MYSQL_DEV_OUTPUT_MODE=per_database
MYSQL_DEV_BACKUP_DIR=/data/backup/mysql/dev
MYSQL_DEV_SINGLE_TRANSACTION=true
MYSQL_DEV_QUICK=true
MYSQL_DEV_ROUTINES=true
MYSQL_DEV_EVENTS=true
MYSQL_DEV_TRIGGERS=true
MYSQL_DEV_HEX_BLOB=true
MYSQL_DEV_SET_GTID_PURGED=OFF
MYSQL_DEV_COLUMN_STATISTICS=false
MYSQL_DEV_LOCK_TABLES=false
MYSQL_DEV_DUMP_CREATE_DATABASE=false
MYSQL_DEV_RESTORE_HOST=127.0.0.1
MYSQL_DEV_RESTORE_PORT=3306
MYSQL_DEV_RESTORE_USER=root
MYSQL_DEV_RESTORE_PASSWORD_ENV=MYSQL_DEV_RESTORE_PASSWORD
# MYSQL_DEV_RESTORE_PASSWORD_FILE=/etc/dbbackupctl/mysql-dev-restore.pass
MYSQL_DEV_RETENTION_KEEP_LAST=7
MYSQL_DEV_RETENTION_KEEP_DAYS=7
MYSQL_DEV_RETENTION_MAX_TOTAL_SIZE=100G

# =============================================================================
# 环境：prod
# =============================================================================

MYSQL_PROD_ENABLED=true
MYSQL_PROD_HOST=127.0.0.1
MYSQL_PROD_PORT=3306
MYSQL_PROD_USER=backup_user
MYSQL_PROD_PASSWORD_ENV=MYSQL_PROD_PASSWORD
# MYSQL_PROD_PASSWORD_FILE=/etc/dbbackupctl/mysql-prod.pass
MYSQL_PROD_DATABASES=prod_app,prod_report
MYSQL_PROD_INCLUDE_SYSTEM_DATABASES=false
MYSQL_PROD_BACKUP_MODE=logical
MYSQL_PROD_OUTPUT_MODE=per_database
MYSQL_PROD_BACKUP_DIR=/data/backup/mysql/prod
MYSQL_PROD_SINGLE_TRANSACTION=true
MYSQL_PROD_QUICK=true
MYSQL_PROD_ROUTINES=true
MYSQL_PROD_EVENTS=true
MYSQL_PROD_TRIGGERS=true
MYSQL_PROD_HEX_BLOB=true
MYSQL_PROD_SET_GTID_PURGED=OFF
MYSQL_PROD_COLUMN_STATISTICS=false
MYSQL_PROD_LOCK_TABLES=false
MYSQL_PROD_DUMP_CREATE_DATABASE=false
MYSQL_PROD_RESTORE_HOST=127.0.0.1
MYSQL_PROD_RESTORE_PORT=3306
MYSQL_PROD_RESTORE_USER=root
MYSQL_PROD_RESTORE_PASSWORD_ENV=MYSQL_PROD_RESTORE_PASSWORD
# MYSQL_PROD_RESTORE_PASSWORD_FILE=/etc/dbbackupctl/mysql-prod-restore.pass
MYSQL_PROD_RETENTION_KEEP_LAST=14
MYSQL_PROD_RETENTION_KEEP_DAYS=14
MYSQL_PROD_RETENTION_MAX_TOTAL_SIZE=300G
