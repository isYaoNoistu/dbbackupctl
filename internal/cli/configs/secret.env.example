# dbbackupctl 敏感配置示例
# 必须限制权限：chmod 600 /etc/dbbackupctl/secret.env

MYSQL_DEV_PASSWORD='your_mysql_dev_backup_password'
MYSQL_DEV_RESTORE_PASSWORD='your_mysql_dev_restore_password'
MYSQL_PROD_PASSWORD='your_mysql_prod_backup_password'
MYSQL_PROD_RESTORE_PASSWORD='your_mysql_prod_restore_password'

POSTGRES_DEV_PASSWORD='your_postgres_dev_backup_password'
POSTGRES_DEV_RESTORE_PASSWORD='your_postgres_dev_restore_password'
POSTGRES_PROD_PASSWORD='your_postgres_prod_backup_password'
POSTGRES_PROD_RESTORE_PASSWORD='your_postgres_prod_restore_password'

# DBB_ENCRYPTION_KEY='your_encryption_key'
